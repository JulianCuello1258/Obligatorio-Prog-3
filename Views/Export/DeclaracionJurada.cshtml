@model IEnumerable<BeeKeeperApp.Models.Entities.Apiario>

@{
    Layout = null;
    var totalColmenas = Model.Sum(a => a.Colmenas.Count);
    var hoy = DateTime.Now;
    var validaHasta = new DateTime(hoy.Year + 1, 6, 30);
    var rna = new Random().Next(100000, 999999).ToString();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <style>
        body { font-family: Arial, sans-serif; padding: 40px; line-height: 1.4; color: #000; max-width: 900px; margin: 0 auto; }
        .print-btn { background: #007bff; color: white; padding: 12px 24px; border: none; cursor: pointer; margin-bottom: 20px; font-size: 16px; border-radius: 4px; display: block; margin-left: auto; margin-right: auto; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .print-btn:hover { background: #0056b3; }
        @@media print { 
            .print-btn { display: none; } 
            body { padding: 0; max-width: 100%; }
        }
        
        .header-container { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .logos { display: flex; align-items: center; width: 100%; justify-content: space-between; }
        
        .title-section { text-align: center; margin-bottom: 30px; }
        .title-section h1 { font-size: 22px; font-weight: normal; margin: 0; letter-spacing: 1px; }
        .title-section h2 { font-size: 18px; font-weight: bold; margin: 8px 0; }
        .title-section h3 { font-size: 12px; font-weight: bold; margin: 0; }
        
        .meta-info { display: flex; justify-content: space-between; margin-bottom: 30px; padding: 0 40px; font-size: 13px; }
        .meta-column { display: flex; flex-direction: column; gap: 5px; }
        
        .section { margin-bottom: 20px; }
        .section-title { background-color: #dbdbdb; padding: 12px 15px; font-weight: bold; font-size: 18px; margin: 0 0 15px 0; }
        .bg-light-gray { background-color: #f0f0f0; padding-bottom: 20px; }
        
        .form-row { display: flex; flex-wrap: wrap; gap: 30px; margin-bottom: 20px; padding: 0 15px; }
        .form-group { display: flex; flex-direction: column; flex: 1; min-width: 200px; }
        .form-group label { font-size: 11px; color: #333; margin-top: 5px; }
        .form-group input { border: none; border-bottom: 1px solid #000; padding: 5px 0; font-size: 14px; font-family: inherit; font-weight: bold; outline: none; background: transparent; }
        
        .footer-note { margin-top: 40px; font-size: 10px; border: 1px solid #000; background-color: #e6e6e6; padding: 10px; text-align: justify; }
        .footer-note-light { font-size: 10px; background-color: #f2f2f2; padding: 10px; text-align: justify; border: 1px solid #000; border-top: none; }
    </style>
</head>
<body>
    <div class="header-container">
        <img src="/Images/Formulario-Min-Ganaderia-Cabecera.PNG" width="900" style="display: flex; justify-content: center" />
    </div>

    <div class="title-section">
        <h1>REGISTRO NACIONAL DE APICULTORES</h1>
        <h2>Declaración Jurada @hoy.Year</h2>
        <h3>Período 01/07/@hoy.Year - 31/07/@hoy.Year</h3>
    </div>

    <div class="meta-info">
        <div class="meta-column">
            <div>Número de RNA: <strong>@rna</strong></div>
            <div>Fecha de aprobación de Declaración: <strong>@hoy.ToString("dd/MM/yyyy")</strong></div>
        </div>
        <div class="meta-column" style="margin-right: 80px;">
            <div>Válida hasta: <strong>@validaHasta.ToString("dd/MM/yyyy")</strong></div>
            <div>Estado: <strong>Aprobada</strong></div>
        </div>
    </div>

    <div class="section">
        <div class="section-title">A. PERSONA FÍSICA O JURÍDICA</div>
        <div class="form-row">
            <div class="form-group">
                <input type="text" id="nombreApellidoApicultor" value="" placeholder="" />
                <label for="nombreApellidoApicultor">Nombre y Apellido del apicultor</label>
            </div>
            <div class="form-group">
                <input type="date" id="fechaNacimiento" value="" placeholder="" />
                <label for="fechaNacimiento">Fecha de nacimiento</label>
            </div>
            <div class="form-group">
                <input type="text" id="documento" value="" placeholder="" />
                <label for="documento">Documento de identidad</label>
            </div>
        </div>
    </div>

    <div class="section bg-light-gray">
        <div class="section-title">B. DOMICILIO</div>
        <div class="form-row">
            <div class="form-group">
                <input type="text" id="colonia" />
                <label for="colonia">Departamento</label>
            </div>
            <div class="form-group">
                <input type="text" id="seccion" />
                <label for="seccion">Sección policial</label>
            </div>
            <div class="form-group">
                <input type="text" id="camino" />
                <label for="camino">Dirección / camino</label>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <input type="text" id="celPrincipal" value="" />
                <label for="celPrincipal">Celular de contacto principal</label>
            </div>
            <div class="form-group">
                <input type="text" id="celSecundario" value="" />
                <label for="celSecundario">Celular de contacto secundario (Opcional)</label>
            </div>
            <div class="form-group">
                <input type="text" id="email" value="" />
                <label for="email">Correo electrónico</label>
            </div>
            
        </div>
    </div>

    <div class="section bg-light-gray" style="margin-bottom: 0;">
        <div class="section-title">C. STOCK APÍCOLA</div>
        <div class="form-row">
            <div class="form-group">
                <input type="text" id="colmenas" value="@totalColmenas" readonly style="border-bottom:none" />
                <label for="colmenas">Cantidad de colmenas en propiedad</label>
            </div>
            <div class="form-group">
                <input type="text" id="nucleos" value="0" style="border-bottom:none" />
                <label for="nucleos">Cantidad de núcleos</label>
            </div>
            <div class="form-group">
            </div>
        </div>
    </div>

    <div class="footer-note">
        <strong>La presente declaración jurada está exonerada del pago del timbre de la Caja de Jubilaciones y Pensiones de Profesionales Universitarios, según Ley 19.535 del 25 de setiembre de 2017, Art. 93.</strong>
    </div>
    <div class="footer-note-light">
        Se deja constancia que la información proporcionada en este formulario tiene carácter de declaración jurada, con sujeción a las sanciones legalmente establecidas y será de carácter reservado. Según la Ley 18.719 del año 2010, Art. 380, y Decreto Reglamentario 371 del año 2013, Art. 1, 2, 7 y 8, los titulares de las explotaciones apícolas deberán actualizar sus datos al menos una vez al año bajo el régimen de declaración jurada. Una vez confirmada su declaración podrá descargar una copia de su declaración jurada.
    </div>

    <br />
    <button class="print-btn" onclick="window.print()">🖨️ Imprimir Declaración</button>

</body>
</html>
