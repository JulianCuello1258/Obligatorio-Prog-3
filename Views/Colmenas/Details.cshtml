@model BeeKeeperApp.Models.Entities.Colmena

@{
    ViewData["Title"] = "Detalles de Colmena";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-card">
            <h2>Colmena: #@Model.Id</h2>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">Apiario</dt>
                <dd class="col-sm-9">@(Model.Apiario?.Nombre ?? "N/A")</dd>

                <dt class="col-sm-3">Estado</dt>
                <dd class="col-sm-9">
                    @if (Model.Estado == BeeKeeperApp.Models.Entities.EstadoColmena.Activa)
                    {
                        <span class="badge bg-success">Activa</span>
                    }
                    else if (Model.Estado == BeeKeeperApp.Models.Entities.EstadoColmena.Inactiva)
                    {
                        <span class="badge bg-secondary">Inactiva</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Perdida</span>
                    }
                </dd>

                <dt class="col-sm-3">Tipo</dt>
                <dd class="col-sm-9">@Model.Tipo</dd>

                <dt class="col-sm-3">Población</dt>
                <dd class="col-sm-9">@Model.Poblacion</dd>

                <dt class="col-sm-3">Temperamento</dt>
                <dd class="col-sm-9">@Model.Temperamento</dd>

                <dt class="col-sm-12 mt-3">
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-2">
                        <h5 class="text-honey-dark mb-0">Información de la Reina</h5>
                        @if (Model.Estado == BeeKeeperApp.Models.Entities.EstadoColmena.Activa)
                        {
                            <a asp-action="GestionarReina" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning">Gestionar Reina</a>
                        }
                    </div>
                </dt>
                
                <dt class="col-sm-3 mt-2">Presencia</dt>
                <dd class="col-sm-9">@(Model.Reina?.Presencia == true ? "Presente" : "Ausente")</dd>
                
                @if(Model.Reina?.Presencia == true)
                {
                    <dt class="col-sm-3">ID de la Reina</dt>
                    <dd class="col-sm-9">@Model.Reina?.ColmenaId</dd>

                    <dt class="col-sm-3">Estado de Salud</dt>
                    <dd class="col-sm-9">@Model.Reina?.Salud</dd>

                    <dt class="col-sm-3">Fecha de Nacimiento</dt>
                    <dd class="col-sm-9">@(Model.Reina?.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "No registrada")</dd>
                }
            </dl>

            <hr class="mt-4 mb-4" />
            <h5 class="text-honey-dark mb-3">🍯 Historial de Producción</h5>
            @if (Model.Extracciones != null && Model.Extracciones.Any())
            {
                <div class="table-responsive">
                    <table class="table table-custom align-middle">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Cantidad cosechada</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ext in Model.Extracciones.OrderByDescending(e => e.Fecha))
                            {
                                <tr>
                                    <td>@ext.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td class="fw-bold text-honey-dark">@ext.CantidadKg.ToString("N1") Kg</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted fst-italic">Esta colmena no registra producción hasta el momento.</p>
            }
            
            <div class="mt-4 d-flex gap-2">
                <a asp-controller="Apiarios" asp-action="Details" asp-route-id="@Model.ApiarioId" class="btn btn-outline-secondary">Volver al Apiario</a>
                @if (Model.Estado == BeeKeeperApp.Models.Entities.EstadoColmena.Activa)
                {
                    <a asp-action="DarDeBaja" asp-route-id="@Model.Id" class="btn btn-outline-danger">Eliminar</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-honey">Editar Colmena</a>
                }
                else if (Model.Estado == BeeKeeperApp.Models.Entities.EstadoColmena.Inactiva)
                {
                    <form asp-action="Reactivar" asp-route-id="@Model.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-success">Reactivar</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
