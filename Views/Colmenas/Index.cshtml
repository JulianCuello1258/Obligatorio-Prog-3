@model IEnumerable<BeeKeeperApp.Models.Entities.Colmena>

@{
    ViewData["Title"] = "Gestión de Colmenas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p>
        <a asp-action="Create" class="btn btn-honey">+ Nueva Colmena</a>
    </p>
</div>

<div class="glass-card">
    <table class="table table-custom">
        <thead>
            <tr>
                <th>ID</th>
                <th>Apiario</th>
                <th>Estado</th>
                <th>Tipo</th>
                <th>Población</th>
                <th>Reina</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>#@item.Id</td>
                    <td>
                        @if(item.ApiarioId > 0) {
                            <a href="/Apiarios/Details/@item.ApiarioId" class="text-decoration-none fw-bold text-dark hover-honey">@item.Apiario?.Nombre</a>
                        } else {
                            <span class="text-muted">Sin asignar</span>
                        }
                    </td>
                    <td>
                        <span class="badge @(item.Estado == BeeKeeperApp.Models.Entities.EstadoColmena.Activa ? "bg-success" : "bg-danger")">
                            @item.Estado
                        </span>
                    </td>
                    <td>@item.Tipo</td>
                    <td>@item.Poblacion</td>
                    <td>
                        @(item.Reina?.Presencia == true ? $"✅ Presente (ID: {item.Reina.ColmenaId})" : "❌ Ausente")
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Detalles</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any()) {
    <div class="text-center py-5">
        <img src="/Images/colmenas.png" width="100" style="opacity: 0.3;" />
        <p class="mt-3 text-muted">No hay colmenas registradas aún.</p>
    </div>
}
