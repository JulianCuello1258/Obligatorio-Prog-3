@model BeeKeeperApp.Models.Entities.Colmena
@using BeeKeeperApp.Models.Entities

@{
    ViewData["Title"] = "Editar Colmena";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-card">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FechaCreacion" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <strong>Error:</strong> Por favor, verifique los campos del formulario.
                        <button type="button" class="btn-close" data-bs-alert="dismiss" aria-label="Close"></button>
                    </div>
                }
                
                <div class="mb-3">
                    <label asp-for="ApiarioId" class="form-label fw-bold">Apiario</label>
                    <select asp-for="ApiarioId" class="form-select" asp-items="ViewBag.ApiarioId">
                        <option value="">-- Seleccionar Apiario --</option>
                    </select>
                    <span asp-validation-for="ApiarioId" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Estado" class="form-label fw-bold">Estado</label>
                        <select asp-for="Estado" class="form-select">
                            <option value="Activa">Activa</option>
                            <option value="Inactiva">Inactiva</option>
                        </select>
                        <span asp-validation-for="Estado" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Tipo" class="form-label fw-bold">Tipo</label>
                        <select asp-for="Tipo" class="form-select">
                            <option value="Langstroth">Langstroth</option>
                            <option value="Dadant">Dadant</option>
                            <option value="Jumbo">Jumbo</option>
                            <option value="Otra">Otra</option>
                        </select>
                        <span asp-validation-for="Tipo" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Poblacion" class="form-label fw-bold">Población</label>
                        <select asp-for="Poblacion" class="form-select">
                            <option value="Fuerte">Fuerte</option>
                            <option value="Media">Media</option>
                            <option value="Debil">Débil</option>
                        </select>
                        <span asp-validation-for="Poblacion" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Temperamento" class="form-label fw-bold">Temperamento</label>
                        <select asp-for="Temperamento" class="form-select">
                            <option value="Mansa">Mansa</option>
                            <option value="Agresiva">Agresiva</option>
                        </select>
                        <span asp-validation-for="Temperamento" class="text-danger small"></span>
                    </div>
                </div>

                <hr class="mt-4 mb-4" />
                <h5 class="mb-3 text-honey-dark fw-bold">Información de la Reina</h5>
                <input type="hidden" asp-for="Reina.ColmenaId" />
                <div class="row">
                    <div class="col-md-4 mb-3 d-flex align-items-center">
                        <div class="form-check mt-4">
                            <input asp-for="Reina.Presencia" class="form-check-input" type="checkbox" />
                            <label class="form-check-label fw-bold">Reina Presente</label>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Reina.Salud" class="form-label fw-bold">Estado de Salud</label>
                        <select asp-for="Reina.Salud" class="form-select">
                            <option value="Buena">Buena</option>
                            <option value="Regular">Regular</option>
                            <option value="Mala">Mala</option>
                        </select>
                        <span asp-validation-for="Reina.Salud" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Reina.FechaNacimiento" class="form-label fw-bold">Fecha de Nacimiento</label>
                        <input asp-for="Reina.FechaNacimiento" class="form-control" type="date" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="Reina.FechaNacimiento" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancelar</a>
                    <div class="d-flex gap-2">
                        @if (Model.Estado == EstadoColmena.Activa)
                        {
                            <a asp-action="DarDeBaja" asp-route-id="@Model.Id" class="btn btn-outline-danger">Eliminar</a>
                        }
                        <button type="submit" class="btn btn-honey">Guardar Cambios</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
