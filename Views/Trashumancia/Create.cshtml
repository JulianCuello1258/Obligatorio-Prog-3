@model BeeKeeperApp.Models.Entities.Trashumancia

@{
    ViewData["Title"] = "Nuevo Traslado";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-card">
            <h2 class="h4 mb-4">Registrar Nuevo Traslado</h2>
            <form asp-action="Create">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ApiarioOrigenId" class="form-label">Apiario Origen</label>
                        <select asp-for="ApiarioOrigenId" class="form-select" asp-items="ViewBag.Apiarios" required></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ApiarioDestinoId" class="form-label">Apiario Destino</label>
                        <select asp-for="ApiarioDestinoId" class="form-select" asp-items="ViewBag.Apiarios" required></select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Fecha" class="form-label">Fecha</label>
                        <input asp-for="Fecha" class="form-control" type="date" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DistanciaKm" class="form-label">Distancia (Km)</label>
                        <input asp-for="DistanciaKm" class="form-control" type="number" step="0.1" required />
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-honey w-100">Guardar Traslado</button>
                    <a asp-action="Index" class="btn btn-link w-100 mt-2">Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>
