@model IEnumerable<BeeKeeperApp.Models.Entities.Trashumancia>

@{
    ViewData["Title"] = "Movimientos de Trashumancia";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <a asp-action="Create" class="btn btn-honey">+ Registrar Traslado</a>
    </div>
    <form method="get" class="sort-control">
        <span class="sort-label">Ordenar por:</span>
        <select name="sortBy" onchange="this.form.submit()">
            <option value="Fecha" selected="@(ViewBag.SortBy == "Fecha")">Fecha</option>
            <option value="Distancia" selected="@(ViewBag.SortBy == "Distancia")">Distancia</option>
        </select>
        <a href="?sortBy=@ViewBag.SortBy&descending=@((!ViewBag.Descending).ToString().ToLower())" class="sort-dir-btn" title="Cambiar dirección de orden">
            @(ViewBag.Descending == true ? "▲" : "▼")
        </a>
    </form>
</div>

<div class="glass-card">
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th class="text-nowrap">Fecha</th>
                    <th class="text-nowrap">Colmena</th>
                    <th class="text-nowrap">Origen</th>
                    <th class="text-nowrap">Destino</th>
                    <th class="text-nowrap">Distancia</th>
                    <th class="text-nowrap text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="text-nowrap">@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td class="text-nowrap">
                            @if (item.Colmena?.Estado == BeeKeeperApp.Models.Entities.EstadoColmena.Perdida)
                            {
                                <span>Colmena #@item.ColmenaId (Perdida)</span>
                            }
                            else
                            {
                                <a href="/Colmenas/Details/@item.ColmenaId" class="text-decoration-none fw-bold text-dark hover-honey">Colmena #@item.ColmenaId</a>
                            }
                        </td>
                        <td class="text-nowrap">@(item.ApiarioOrigen?.Nombre ?? "-")</td>
                        <td class="text-nowrap">@(item.ApiarioDestino?.Nombre ?? "-")</td>
                        <td class="text-nowrap fw-bold text-honey-dark">@item.DistanciaKm.ToString("N2") Km</td>
                        <td class="text-nowrap text-end">
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Está seguro de que desea quitar este traslado? Esta acción solo eliminará el registro y no afectará la ubicación actual de la colmena.');" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Quitar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
