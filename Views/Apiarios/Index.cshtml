@model IEnumerable<BeeKeeperApp.Models.Entities.Apiario>

@{
    ViewData["Title"] = "Gestión de Apiarios";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <a asp-action="Create" class="btn btn-honey">+ Registrar Apiario</a>
        <a asp-action="Comparacion" class="btn btn-outline-info ms-2">Comparar Apiarios</a>
    </div>
    <form method="get" class="sort-control">
        <span class="sort-label">Ordenar por:</span>
        <select name="sortBy" onchange="this.form.submit()">
            <option value="Nombre" selected="@(ViewBag.SortBy == "Nombre")">Nombre</option>
            <option value="Fecha" selected="@(ViewBag.SortBy == "Fecha")">Fecha de Creación</option>
            <option value="Produccion" selected="@(ViewBag.SortBy == "Produccion")">Producción</option>
        </select>
        <a href="?sortBy=@ViewBag.SortBy&descending=@((!ViewBag.Descending).ToString().ToLower())" class="sort-dir-btn" title="Cambiar dirección de orden">
            @(ViewBag.Descending == true ? "▲" : "▼")
        </a>
    </form>
</div>

<div class="row">
    @foreach (var item in Model) {
        <div class="col-md-4 mb-4">
            <div class="glass-card h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h3 class="h5 mb-0">@item.Nombre</h3>
                    <span class="badge @(item.Tipo == BeeKeeperApp.Models.Entities.TipoApiario.Fijo ? "bg-info" : "bg-warning text-dark")">
                        @item.Tipo
                    </span>
                </div>
                
                <p class="text-muted small">
                    <img src="/Images/marcador-de-mapa.png" width="16" /> @item.Zona, @item.SeccionPolicial
                </p>

                @{
                    var produccionTotal = item.Colmenas.SelectMany(c => c.Extracciones).Sum(e => e.CantidadKg);
                }
                <div class="stats-grid mt-3">
                    <div class="stat-item">
                        <a href="/Colmenas?apiarioId=@item.Id" class="text-decoration-none text-dark">
                            <div class="stat-value text-honey hover-scale" style="font-size: 1.2rem;">@item.Colmenas.Count</div>
                            <div class="stat-label">Colmenas</div>
                        </a>
                    </div>
                </div>
                <p class="mt-2 mb-0 small" style="color: #b8860b; font-weight: 600;">
                    Producido: <span style="font-weight: 700;">@produccionTotal.ToString("N1") kg</span>
                </p>

                <div class="mt-4 d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Detalles</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any()) {
    <div class="text-center py-5">
        <img src="/Images/apiarios.png" width="100" style="opacity: 0.3;" />
        <p class="mt-3 text-muted">No hay apiarios registrados aún.</p>
    </div>
}
