@model BeeKeeperApp.Models.Entities.Apiario
@using BeeKeeperApp.Models.Entities

@{
    ViewData["Title"] = "Detalle de Apiario";

    var extraccionesApiario = (ViewBag.ExtraccionesApiario as List<Extraccion>) ?? new List<Extraccion>();
    var totalApiarioKg = extraccionesApiario.Sum(e => e.CantidadKg);

    // Colmenas activas para calcular la parte proporcional
    var colmenasActivas = Model.Colmenas.Where(c => c.Estado == EstadoColmena.Activa).ToList();
    int cantActivas = colmenasActivas.Count > 0 ? colmenasActivas.Count : 1;
    double kgPorColmenaActiva = totalApiarioKg / cantActivas;

    // Producción total = extracciones individuales por colmena + extracciones de apiario
    var produccionTotalApiario = Model.Colmenas.SelectMany(c => c.Extracciones).Sum(e => e.CantidadKg) + totalApiarioKg;
}

<div class="row">
    <div class="col-md-4">
        <div class="glass-card">
            <h2 class="h4 mb-3">@Model.Nombre</h2>
            <p><strong>Ubicación:</strong> @Model.Latitud, @Model.Longitud</p>
            <p><strong>Tipo:</strong> @Model.Tipo</p>
            <p><strong>Zona:</strong> @Model.Zona</p>
            <p><strong>Sección:</strong> @Model.SeccionPolicial</p>
            <hr />
            <div class="text-center py-2 px-3 rounded mb-3" style="background: linear-gradient(135deg, #fff8e1, #ffe082); border: 1px solid #f0c040;">
                <div style="font-size: 1.8rem;">🍯</div>
                <div style="font-size: 1.5rem; font-weight: 700; color: #b8860b;">@produccionTotalApiario.ToString("0.##") kg</div>
                <div class="text-muted small">Producción total del apiario</div>
            </div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-honey w-100 mb-2">Editar</a>
            <a asp-action="Index" class="btn btn-outline-dark w-100">Volver</a>
        </div>
    </div>
    <div class="col-md-8">
        <div class="glass-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="h5">Colmenas en este Apiario</h3>
                <a asp-controller="Colmenas" asp-action="Create" asp-route-apiarioId="@Model.Id" class="btn btn-sm btn-honey">+ Nueva Colmena</a>
            </div>
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Estado</th>
                        <th>Tipo</th>
                        <th>🍯 Producción</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Colmenas) {
                        var prodColmena = c.Extracciones.Sum(e => e.CantidadKg);
                        // Sumar parte proporcional de extracciones de apiario (solo colmenas activas)
                        if (c.Estado == EstadoColmena.Activa && kgPorColmenaActiva > 0)
                        {
                            prodColmena += kgPorColmenaActiva;
                        }
                        <tr>
                            <td>#@c.Id</td>
                            <td>@c.Estado</td>
                            <td>@c.Tipo</td>
                            <td>
                                @if (prodColmena > 0) {
                                    <span class="badge" style="background:#f0c040; color:#333; font-size:0.85rem;">@prodColmena.ToString("0.##") kg</span>
                                } else {
                                    <span class="text-muted small">Sin producción</span>
                                }
                            </td>
                            <td>
                                @if (c.Estado != EstadoColmena.Perdida)
                                {
                                    <a asp-controller="Colmenas" asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
