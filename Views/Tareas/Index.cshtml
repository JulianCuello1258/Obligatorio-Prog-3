@model IEnumerable<BeeKeeperApp.Models.Entities.Tarea>

@{
    ViewData["Title"] = "Tareas y Recordatorios";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <a asp-action="Create" class="btn btn-honey">+ Nueva Tarea</a>
    </div>
    <form method="get" class="sort-control">
        <span class="sort-label">Ordenar por:</span>
        <select name="sortBy" onchange="this.form.submit()">
            <option value="Fecha" selected="@(ViewBag.SortBy == "Fecha")">Fecha Programada</option>
            <option value="Titulo" selected="@(ViewBag.SortBy == "Titulo")">Título</option>
            <option value="Estado" selected="@(ViewBag.SortBy == "Estado")">Estado</option>
        </select>
        <a href="?sortBy=@ViewBag.SortBy&descending=@((!ViewBag.Descending).ToString().ToLower())" class="sort-dir-btn" title="Cambiar dirección de orden">
            @(ViewBag.Descending == true ? "▲" : "▼")
        </a>
    </form>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="glass-card">
            <div class="table-responsive">
                <table class="table table-custom align-middle">
                    <thead>
                        <tr>
                            <th class="text-nowrap">Fecha</th>
                            <th class="text-nowrap">Título</th>
                            <th>Descripción</th>
                            <th class="text-nowrap">Referencia</th>
                            <th class="text-nowrap">Estado</th>
                            <th class="text-nowrap text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr class="@(item.FechaProgramada < DateTime.Now && !item.Completada ? "table-danger" : "")">
                                <td class="text-nowrap">@item.FechaProgramada.ToString("dd/MM/yyyy")</td>
                                <td class="text-nowrap"><strong>@(string.IsNullOrEmpty(item.Titulo) ? "-" : item.Titulo)</strong></td>
                                <td>@item.Descripcion</td>
                                <td class="text-nowrap">
                                    @if (item.ColmenaId.HasValue) {
                                        <span>Colmena #@item.ColmenaId</span>
                                    } else if (item.ApiarioId.HasValue) {
                                        <span>Apiario @item.ApiarioId</span>
                                    }
                                </td>
                                <td class="text-nowrap">
                                    @if (item.Completada) {
                                        <span class="badge bg-success">Completada</span>
                                    } else {
                                        <span class="badge bg-warning text-dark">Pendiente</span>
                                    }
                                </td>
                                <td class="text-nowrap text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Detalles</a>
                                        @if (!item.Completada) {
                                            <form asp-action="MarkCompleted" method="post" style="display:inline">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-honey">Completar</button>
                                            </form>
                                        }
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('¿Está seguro de que desea eliminar esta tarea?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
