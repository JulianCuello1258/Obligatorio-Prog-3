@model IEnumerable<BeeKeeperApp.Models.Entities.Tarea>

@{
    ViewData["Title"] = "Tareas y Recordatorios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p>
        <a asp-action="Create" class="btn btn-honey">+ Nueva Tarea</a>
    </p>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="glass-card">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Título</th>
                        <th>Descripción</th>
                        <th>Referencia</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr class="@(item.FechaProgramada < DateTime.Now && !item.Completada ? "table-danger" : "")">
                            <td>@item.FechaProgramada.ToShortDateString()</td>
                            <td><strong>@item.Titulo</strong></td>
                            <td>@item.Descripcion</td>
                            <td>
                                @if (item.ColmenaId.HasValue) {
                                    <span>Colmena #@item.ColmenaId</span>
                                } else if (item.ApiarioId.HasValue) {
                                    <span>Apiario @item.ApiarioId</span>
                                }
                            </td>
                            <td>
                                @if (item.Completada) {
                                    <span class="badge bg-success">Completada</span>
                                } else {
                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                }
                            </td>
                            <td>
                                @if (!item.Completada) {
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-2">Ver Detalles</a>
                                    <form asp-action="MarkCompleted" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-honey">Completar</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
