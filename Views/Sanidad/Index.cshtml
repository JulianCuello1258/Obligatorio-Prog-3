@model IEnumerable<BeeKeeperApp.Models.Entities.Revision>

@{
    ViewData["Title"] = "Control Sanitario";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p>
        <a asp-action="Create" class="btn btn-honey">+ Nueva Inspección Sanitaria</a>
    </p>
</div>

<div class="glass-card">
    <table class="table table-custom">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Colmena</th>
                <th>Estado General</th>
                <th>Enfermedad</th>
                <th>Tratamiento</th>
                <th>Próxima Dosis</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.Fecha.ToShortDateString()</td>
                    <td>#@item.ColmenaId</td>
                    <td>
                        @if (string.IsNullOrEmpty(item.Enfermedades)) {
                            <span class="badge bg-success">Saludable</span>
                        } else {
                            <span class="badge bg-danger">Enferma</span>
                        }
                    </td>
                    <td>@(item.Enfermedades ?? "Ninguna")</td>
                    <td>@(item.Tratamiento ?? "-")</td>
                    <td>
                        @if (item.ProximaDosis.HasValue) {
                            <span class="text-warning">@item.ProximaDosis.Value.ToShortDateString()</span>
                        } else {
                            <span>-</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Detalles</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any()) {
    <div class="text-center py-5">
        <img src="/Images/tratamiento.png" width="100" style="opacity: 0.3;" />
        <p class="mt-3 text-muted">No hay registros sanitarios registrados aún.</p>
    </div>
}
