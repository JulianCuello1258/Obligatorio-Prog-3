@model IEnumerable<BeeKeeperApp.Models.Entities.Revision>

@{
    ViewData["Title"] = "Inspecciones";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <a asp-action="Create" class="btn btn-honey">+ Nueva Inspección</a>
    </div>
    <form method="get" class="sort-control">
        <span class="sort-label">Ordenar por:</span>
        <select name="sortBy" onchange="this.form.submit()">
            <option value="Fecha" selected="@(ViewBag.SortBy == "Fecha")">Fecha</option>
            <option value="Colmena" selected="@(ViewBag.SortBy == "Colmena")">ID</option>
            <option value="Enfermedad" selected="@(ViewBag.SortBy == "Enfermedad")">Enfermedad</option>
        </select>
        <a href="?sortBy=@ViewBag.SortBy&descending=@((!ViewBag.Descending).ToString().ToLower())" class="sort-dir-btn" title="Cambiar dirección de orden">
            @(ViewBag.Descending == true ? "▲" : "▼")
        </a>
    </form>
</div>

<div class="glass-card">
    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th class="text-nowrap">Fecha</th>
                    <th class="text-nowrap">Colmena</th>
                    <th class="text-nowrap">Estado General</th>
                    <th class="text-nowrap">Enfermedad</th>
                    <th class="text-nowrap">Tratamiento</th>
                    <th class="text-nowrap">Próxima Dosis</th>
                    <th class="text-nowrap text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="text-nowrap">@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td class="text-nowrap">
                            @if (item.ColmenaId > 0) {
                                <a href="/Colmenas/Details/@item.ColmenaId" class="text-decoration-none fw-bold text-dark hover-honey">#@item.ColmenaId</a>
                            } else {
                                <span class="text-muted fst-italic">Apiario completo</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            @if (string.IsNullOrEmpty(item.Enfermedades) || item.Enfermedades == "Ninguna") {
                                <span class="badge bg-success">Saludable</span>
                            } else {
                                <span class="badge bg-danger">Enferma</span>
                            }
                        </td>
                        <td class="text-nowrap">@(item.Enfermedades ?? "Ninguna")</td>
                        <td class="text-nowrap">@(item.Tratamiento ?? "-")</td>
                        <td class="text-nowrap">
                            @if (item.ProximaDosis.HasValue) {
                                <span class="text-warning fw-bold">@item.ProximaDosis.Value.ToString("dd/MM/yyyy")</span>
                            } else {
                                <span>-</span>
                            }
                        </td>
                        <td class="text-nowrap text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Detalles</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('¿Está seguro de que desea eliminar esta inspección?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Quitar</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any()) {
    <div class="text-center py-5">
        <img src="/Images/tratamiento.png" width="100" style="opacity: 0.3;" />
        <p class="mt-3 text-muted">No hay registros sanitarios registrados aún.</p>
    </div>
}
