@model BeeKeeperApp.Models.DashboardViewModel

@{
    ViewData["Title"] = "Panel de Control";
}

<div class="stats-grid mb-5">
    <div class="glass-card stat-item">
        <img src="/Images/apiarios.png" width="40" class="mb-2" />
        <div class="stat-value">@Model.TotalApiarios</div>
        <div class="stat-label">Apiarios Totales</div>
    </div>
    <div class="glass-card stat-item">
        <img src="/Images/colmenas.png" width="40" class="mb-2" />
        <div class="stat-value">@Model.TotalColmenasActivas</div>
        <div class="stat-label">Colmenas Activas</div>
    </div>
    <div class="glass-card stat-item">
        <img src="/Images/comprobacion-de-lista.png" width="40" class="mb-2" />
        <div class="stat-value">@Model.TareasPendientes</div>
        <div class="stat-label">Tareas Pendientes</div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="glass-card">
            <h3 class="h5 mb-4">Inspecciones Recientes</h3>
            <table class="table table-custom">
                <tbody>
                    @foreach (var rev in Model.UltimasRevisiones) {
                        <tr>
                            <td>#@rev.ColmenaId</td>
                            <td>@rev.Fecha.ToShortDateString()</td>
                            <td>@rev.Tipo</td>
                            <td>
                                @if (!string.IsNullOrEmpty(rev.Enfermedades)) {
                                    <span class="text-danger">⚠️ @rev.Enfermedades</span>
                                } else {
                                    <span class="text-success">✅ Saludable</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass-card bg-honey-light border-honey">
            <h3 class="h5 mb-4">Acciones Rápidas</h3>
            <div class="d-grid gap-3">
                <a href="/Apiarios/Create" class="btn btn-honey">Registrar Apiario</a>
                <a href="/Sanidad/Create" class="btn btn-outline-dark">Nueva Inspección</a>
                <a href="/Produccion/Create" class="btn btn-outline-dark">Registrar Cosecha</a>
            </div>
        </div>
    </div>
</div>
