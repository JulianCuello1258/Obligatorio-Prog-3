@model BeeKeeperApp.Models.ExtraccionCreateViewModel

@{
    ViewData["Title"] = "Registrar Cosecha";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-card">
            <form asp-action="Create">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <strong>Error:</strong> Por favor, verifique los campos del formulario.
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-bold">Tipo de Registro</label>
                    <div class="d-flex gap-2">
                        <input type="hidden" asp-for="TipoRegistro" id="tipoRegistroInput" value="Apiario" />
                        <button type="button" id="btnColmena" class="btn btn-outline-primary flex-fill" onclick="setTipo('Colmena')">
                            🍯 Por Colmena
                        </button>
                        <button type="button" id="btnApiario" class="btn btn-primary flex-fill" onclick="setTipo('Apiario')">
                            🏠 Por Apiario
                        </button>
                    </div>
                </div>

                <div id="panelColmena" class="mb-3" style="display:none;">
                    <label asp-for="ColmenaId" class="form-label fw-bold">Colmena</label>
                    <select asp-for="ColmenaId" class="form-select" asp-items="ViewBag.ColmenaId">
                        <option value="">-- Seleccionar Colmena --</option>
                    </select>
                    <span asp-validation-for="ColmenaId" class="text-danger small"></span>
                </div>

                <div id="panelApiario" class="mb-3">
                    <label asp-for="ApiarioId" class="form-label fw-bold">Apiario</label>
                    <select asp-for="ApiarioId" class="form-select" asp-items="ViewBag.ApiarioId">
                        <option value="">-- Seleccionar Apiario --</option>
                    </select>
                    <span asp-validation-for="ApiarioId" class="text-danger small"></span>
                    <div class="form-text text-muted">La cosecha se distribuirá proporcionalmente entre todas las colmenas activas del apiario.</div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CantidadKg" class="form-label fw-bold">Cantidad (Kg)</label>
                        <input asp-for="CantidadKg" class="form-control" type="number" step="0.1" min="0.1" required />
                        <span asp-validation-for="CantidadKg" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Fecha" class="form-label fw-bold">Fecha</label>
                        <input asp-for="Fecha" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        <span asp-validation-for="Fecha" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar Cosecha</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function setTipo(tipo) {
            document.getElementById('tipoRegistroInput').value = tipo;
            if (tipo === 'Colmena') {
                document.getElementById('panelColmena').style.display = '';
                document.getElementById('panelApiario').style.display = 'none';
                document.getElementById('btnColmena').className = 'btn btn-primary flex-fill';
                document.getElementById('btnApiario').className = 'btn btn-outline-primary flex-fill';
            } else {
                document.getElementById('panelColmena').style.display = 'none';
                document.getElementById('panelApiario').style.display = '';
                document.getElementById('btnApiario').className = 'btn btn-primary flex-fill';
                document.getElementById('btnColmena').className = 'btn btn-outline-primary flex-fill';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            var tipo = document.getElementById('tipoRegistroInput').value || 'Apiario';
            setTipo(tipo);
        });
    </script>
}
