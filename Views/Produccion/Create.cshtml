@model BeeKeeperApp.Models.Entities.Extraccion

@{
    ViewData["Title"] = "Registrar Cosecha";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="glass-card">
            <h2 class="h4 mb-4">Nueva Extracción de Miel</h2>
            <form asp-action="Create">
                <div class="mb-3">
                    <label asp-for="ColmenaId" class="form-label">Colmena</label>
                    <select asp-for="ColmenaId" class="form-select" asp-items="ViewBag.ColmenaId" required></select>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CantidadKg" class="form-label">Cantidad (Kg)</label>
                        <input asp-for="CantidadKg" class="form-control" type="number" step="0.1" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Fecha" class="form-label">Fecha</label>
                        <input asp-for="Fecha" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-honey w-100">Guardar Cosecha</button>
                    <a asp-action="Index" class="btn btn-link w-100 mt-2">Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>
